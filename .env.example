# ─── NurAI Stage 1 — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values before running locally.
# NEVER commit .env to source control.

# ---------------------------------------------------------------------------
# Ollama / Llama 3 Inference
# ---------------------------------------------------------------------------

# Base URL of the Ollama server.
# Local:  http://localhost:11434
# Azure VM: http://<vm-public-ip>:11434
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model tag to use.  Must be pulled first: `ollama pull llama3:8b`
OLLAMA_MODEL=llama3:8b

# ---------------------------------------------------------------------------
# Azure — used by deploy-azure-vm.sh
# ---------------------------------------------------------------------------

# Azure subscription ID
AZURE_SUBSCRIPTION_ID=

# Azure region (e.g. eastus, westeurope)
AZURE_LOCATION=eastus

# Resource group name for Stage 1 resources
AZURE_RESOURCE_GROUP=rg-muslimAI-stage1

# VM name
AZURE_VM_NAME=muslimAI-llama3-vm

# SSH public-key path (used when creating the VM)
AZURE_SSH_KEY_PATH=~/.ssh/id_rsa.pub

# VM admin username
AZURE_VM_ADMIN=azureuser

# VM size — Standard_NC4as_T4_v3 has 1× T4 GPU (check quota first).
# Fallback CPU-only option: Standard_D4s_v3
AZURE_VM_SIZE=Standard_NC4as_T4_v3

# Auto-shutdown time in UTC (HH:MM).  Leave empty to disable.
AZURE_AUTO_SHUTDOWN_TIME=2200
